
---
// src/components/Gallery.astro
---

<section class="py-24 px-4 md:px-8 max-w-7xl mx-auto" id="galeria">
  {/* Encabezado de la Sección */}
  <h2 data-gallery-reveal style="--gallery-delay: 0ms;" class="font-russo text-4xl md:text-5xl text-blanco-tecnico text-center mb-12 uppercase drop-shadow-md">
    Nuestro Trabajo en Detalle
  </h2>

  {/* Grid de Galería (Bento/Masonry Style) */}
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 auto-rows-[200px]">
    
    {/* Imagen 1: Grande (Ocupa 2 columnas y 2 filas) */}
    <div data-gallery-reveal style="--gallery-delay: 120ms;" class="col-span-2 row-span-2 relative group overflow-hidden rounded-2xl border border-plata/10 shadow-lg hover:shadow-[0_0_20px_rgba(255,152,0,0.2)] transition-shadow">
      <img 
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
        data-alt="A close-up shot of a technician opening a luxury vehicle door using specialized non-destructive tools..." 
        src="/porquemillave.jpg" 
        alt="Apertura de Vehículos de Alta Gama"
      />
      {/* Overlay Oscuro con Texto */}
      <div class="absolute inset-0 bg-gradient-to-t from-negro-carbon/90 via-negro-carbon/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
        <p class="text-naranja-dorado font-bebas text-3xl tracking-wide drop-shadow-md transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
          Apertura de Vehículos de Alta Gama
        </p>
      </div>
    </div>

    {/* Imagen 2: Ancha (Ocupa 2 columnas y 1 fila) */}
    <div data-gallery-reveal style="--gallery-delay: 220ms;" class="col-span-2 relative group overflow-hidden rounded-2xl border border-plata/10 shadow-lg hover:shadow-[0_0_20px_rgba(255,152,0,0.2)] transition-shadow">
      <img 
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
        data-alt="Display of several high-security electronic and biometric door locks in a modern showroom..." 
        src="/porquemillave.jpg" 
        alt="Cerraduras Inteligentes"
      />
      {/* Overlay Oscuro con Texto */}
      <div class="absolute inset-0 bg-gradient-to-t from-negro-carbon/90 via-negro-carbon/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
        <p class="text-naranja-dorado font-bebas text-2xl tracking-wide drop-shadow-md transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
          Cerraduras Inteligentes
        </p>
      </div>
    </div>

    {/* Imagen 3: Pequeña (Ocupa 1 columna y 1 fila) */}
    <div data-gallery-reveal style="--gallery-delay: 320ms;" class="relative group overflow-hidden rounded-2xl border border-plata/10 shadow-lg hover:shadow-[0_0_20px_rgba(255,152,0,0.2)] transition-shadow">
      <img 
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
        data-alt="A professional locksmith installing a high-security cylinder into a solid wood door..." 
        src="/porquemillave.jpg" 
        alt="Instalación de chapas"
      />
      <div class="absolute inset-0 bg-negro-carbon/20 group-hover:bg-transparent transition-colors duration-300"></div>
    </div>

    {/* Imagen 4: Pequeña (Ocupa 1 columna y 1 fila) */}
    <div data-gallery-reveal style="--gallery-delay: 420ms;" class="relative group overflow-hidden rounded-2xl border border-plata/10 shadow-lg hover:shadow-[0_0_20px_rgba(255,152,0,0.2)] transition-shadow">
      <img 
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
        data-alt="A row of expertly cut keys lying on a dark textured surface, illuminated by a single directional light source..." 
        src="/porquemillave.jpg" 
        alt="Duplicado de llaves"
      />
      <div class="absolute inset-0 bg-negro-carbon/20 group-hover:bg-transparent transition-colors duration-300"></div>
    </div>

  </div>
</section>

<style>
  [data-gallery-reveal] {
    opacity: 0;
    transform: translate3d(0, 44px, 0) scale(0.975);
    filter: blur(10px);
    transition:
      opacity 780ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 880ms cubic-bezier(0.22, 1, 0.36, 1),
      filter 880ms cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--gallery-delay, 0ms);
    will-change: opacity, transform, filter;
  }

  [data-gallery-reveal].is-visible {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
    filter: blur(0);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-gallery-reveal] {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }
  }
</style>

<script>
  const initGalleryReveal = () => {
    const elements = document.querySelectorAll('[data-gallery-reveal]');

    if (!elements.length) return;

    if (!('IntersectionObserver' in window)) {
      elements.forEach((element) => element.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;

          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      },
      {
        threshold: 0.18,
        rootMargin: '0px 0px -8% 0px',
      }
    );

    elements.forEach((element) => observer.observe(element));
  };

  initGalleryReveal();

  document.addEventListener('astro:page-load', initGalleryReveal);
</script>
