
---
// src/components/Header.astro
---

<header class="bg-negro-carbon border-b border-plata/10 sticky top-0 z-50 shadow-lg">
  <nav class="px-6 md:px-8 max-w-7xl mx-auto py-4 flex items-center justify-between relative">
    
    {/* Logo de la Cerrajería (Imagen) */}
    <a href="/" class="z-50 relative block transition-transform duration-300 hover:scale-105">
      <picture>
  <img
    src="/logomillave.png"
    alt="Logo Mi Llave O.B Cerrajería"
    width="144"
    height="128"
    loading="eager"
    decoding="async"
    fetchpriority="high"
    class="h-12 md:h-16 w-auto object-contain drop-shadow-[0_2px_10px_rgba(0,0,0,0.5)]"
  />
</picture>
    </a>

    {/* Menú Desktop (Estilo Píldora) */}
    <div class="hidden md:flex items-center bg-grafito border border-plata/10 rounded-full px-1.5 py-1.5 gap-1 shadow-inner shadow-black/50">
      <a href="#" class="px-6 py-2 rounded-full text-xl font-bebas tracking-wide transition-all duration-300 bg-naranja-dorado text-negro-carbon shadow-[0_0_10px_rgba(255,152,0,0.3)]">
        Inicio
      </a>
      <a href="#servicios" class="px-6 py-2 rounded-full text-xl font-bebas tracking-wide transition-all duration-300 text-cromo-medio hover:text-naranja-dorado hover:bg-naranja-dorado/10">
        Servicios
      </a>
      <a href="#nosotros" class="px-6 py-2 rounded-full text-xl font-bebas tracking-wide transition-all duration-300 text-cromo-medio hover:text-naranja-dorado hover:bg-naranja-dorado/10">
        Nosotros
      </a>
      <a href="#cobertura" class="px-6 py-2 rounded-full text-xl font-bebas tracking-wide transition-all duration-300 text-cromo-medio hover:text-naranja-dorado hover:bg-naranja-dorado/10">
        Cobertura
      </a>
      <a href="#ubicacion" class="px-6 py-2 rounded-full text-xl font-bebas tracking-wide transition-all duration-300 text-cromo-medio hover:text-naranja-dorado hover:bg-naranja-dorado/10">
        Ubicación
      </a>
    </div>

    {/* Botón WhatsApp Desktop */}
    <a href="https://wa.me/573247355486?text=Hola,%20vengo%20de%20la%20p%C3%A1gina%20web.%20Quiero%20hacer%20una%20consulta." target="_blank" class="hidden md:flex items-center gap-3 bg-[#25D366] text-blanco-tecnico hover:brightness-110 hover:scale-105 text-xl font-bebas tracking-wide pl-6 pr-2 py-2 rounded-full transition-all duration-300 shadow-[0_0_15px_rgba(37,211,102,0.2)]">
      WhatsApp
      <span class="w-8 h-8 rounded-full bg-blanco-tecnico flex items-center justify-center text-[#25D366] shadow-sm">
        <span class="material-symbols-outlined text-[10px]">chat</span>
      </span>
    </a>

    {/* Botón Hamburguesa Mobile */}
    <button id="hamburger" class="md:hidden flex flex-col gap-1.5 cursor-pointer bg-transparent border-0 p-2 z-50 relative">
      <span class="block w-7 h-0.5 bg-blanco-tecnico transition-all duration-300 origin-center"></span>
      <span class="block w-7 h-0.5 bg-naranja-dorado transition-all duration-300"></span>
      <span class="block w-7 h-0.5 bg-blanco-tecnico transition-all duration-300 origin-center"></span>
    </button>

    {/* Overlay oscuro para el menú móvil */}
    <div id="mobileOverlay" class="fixed inset-0 bg-negro-carbon/80 backdrop-blur-sm z-30 opacity-0 pointer-events-none transition-opacity duration-500 md:hidden"></div>

    {/* Menú Mobile Lateral */}
    <div id="mobileMenu" class="fixed top-0 right-0 h-screen w-[85vw] max-w-sm bg-negro-carbon border-l border-plata/10 flex flex-col pt-28 px-6 pb-8 gap-3 md:hidden z-40 shadow-[-10px_0_30px_rgba(0,0,0,0.8)] transition-transform duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] translate-x-full">
      
      <div class="flex flex-col gap-2 overflow-y-auto">
        <a href="#" class="block px-4 py-3 rounded-xl text-2xl font-bebas tracking-wide bg-naranja-dorado text-negro-carbon">Inicio</a>
        <a href="#servicios" class="block px-4 py-3 rounded-xl text-2xl font-bebas tracking-wide text-plata hover:bg-grafito hover:text-naranja-dorado transition-colors">Servicios</a>
        <a href="#nosotros" class="block px-4 py-3 rounded-xl text-2xl font-bebas tracking-wide text-plata hover:bg-grafito hover:text-naranja-dorado transition-colors">Nosotros</a>
        <a href="#cobertura" class="block px-4 py-3 rounded-xl text-2xl font-bebas tracking-wide text-plata hover:bg-grafito hover:text-naranja-dorado transition-colors">Cobertura</a>
        <a href="#ubicacion" class="block px-4 py-3 rounded-xl text-2xl font-bebas tracking-wide text-plata hover:bg-grafito hover:text-naranja-dorado transition-colors">Ubicación</a>
      </div>

      {/* Contenedor inferior: WhatsApp y Redes Sociales */}
      <div class="mt-auto flex flex-col gap-6 pt-6 border-t border-plata/10">
        <a href="https://wa.me/573247355486?text=Hola,%20vengo%20de%20la%20p%C3%A1gina%20web.%20Quiero%20hacer%20una%20consulta." target="_blank" class="flex items-center justify-center gap-3 bg-[#25D366] text-blanco-tecnico text-xl font-bebas tracking-wide px-4 py-2 rounded-full shadow-[0_0_15px_rgba(37,211,102,0.2)] active:scale-95 transition-transform">
          WhatsApp
          <span class="w-6 h-6 rounded-full bg-blanco-tecnico flex items-center justify-center text-[#25D366]">
            <span class="material-symbols-outlined !text-[14px]">chat</span>
          </span>
        </a>

        {/* Redes Sociales */}
        <div class="flex justify-center gap-6">
          {/* Facebook */}
          <a href="https://www.facebook.com/profile.php?id=100052906641769" target="_blank" aria-label="Facebook" class="text-cromo-medio hover:text-naranja-dorado hover:scale-110 transition-all duration-300">
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
