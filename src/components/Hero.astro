
---
// src/components/Hero.astro
---

<section class="relative min-h-[90vh] flex items-center pt-0 overflow-hidden bg-grafito w-full">
  {/* Fondo de Imagen con Degradado Oscuro y Parallax */}
  <div class="absolute inset-0 z-0 overflow-hidden w-full">
    {/* Degradado lateral oscuro para la legibilidad del texto */}
    <div class="absolute inset-0 bg-gradient-to-r from-grafito via-grafito/60 to-transparent z-10 pointer-events-none"></div>
    
    {/* Degradado inferior para borrar el corte de la imagen y fundirlo con la siguiente sección */}
    <div class="absolute inset-x-0 bottom-0 h-40 md:h-64 bg-gradient-to-t from-grafito via-grafito/80 to-transparent z-20 pointer-events-none"></div>
    
    {/* Contenedor animado para el Parallax */}
    <div id="parallax-bg" class="absolute inset-0 w-full h-[120%] -top-[10%] z-0 will-change-transform">
      {/* Imagen para Móvil (Visible solo en pantallas pequeñas) */}
     <img 
  alt="Hero Locksmith Mobile" 
  class="w-full h-full object-cover opacity-80 mix-blend-overlay md:hidden" 
  src="/portada-millave.jpg"
  width="768"
  height="960"
  loading="eager"
  decoding="async"
  fetchpriority="high"
/>
      
      {/* Imagen para PC (Visible desde tamaño md hacia arriba) */}
      <img 
  alt="Hero Locksmith Desktop" 
  class="w-full h-full object-cover opacity-80 mix-blend-overlay hidden md:block" 
  src="/portada-millave.jpg"
  width="1440"
  height="900"
  loading="eager"
  decoding="async"
  fetchpriority="high"
/>
    </div>
  </div>

  {/* Contenedor Principal con animaciones escalonadas */}
  <div class="relative z-30 w-full px-4 md:px-8 max-w-7xl mx-auto grid lg:grid-cols-2 gap-8 md:gap-12 items-center mt-12 md:mt-0">
    <div class="space-y-5 md:space-y-6">
      
      {/* Etiqueta / Badge Superior */}
      <div class="fade-in-up delay-100 inline-flex items-center gap-2 px-3 pt-1 md:px-4 md:py-1.5 bg-naranja-dorado/10 border border-naranja-dorado/30 text-naranja-dorado rounded-full font-bebas text-base sm:text-lg md:text-xl tracking-wider flex-wrap">
        <span class="material-symbols-outlined text-[16px] md:text-[18px]" style="font-variation-settings: 'FILL' 1;">verified</span>
        <span>TU CERRAJERÍA DE CONFIANZA</span>
      </div>

      {/* Título Principal */}
      <h1 class="fade-in-up delay-200 font-russo text-4xl sm:text-[40px] md:text-6xl text-blanco-tecnico leading-tight uppercase drop-shadow-lg">
        CERRAJERO A DOMICILIO EN ZIPAQUIRÁ <br/>
        <span class="text-naranja-dorado">Mi Llave O.B</span>
      </h1>

      {/* Párrafo Descriptivo */}
      <p class="fade-in-up delay-300 font-montserrat text-base sm:text-lg md:text-xl text-plata max-w-xl font-light">
        Servicio de cerrajería urgente 24/7. Especialistas en apertura de carros sin daños, cerrajería residencial y venta de chapas de alta seguridad. Llegamos rápido a cualquier zona de Zipaquirá y alrededores.
      </p>

      {/* Botones de Acción */}
      <div class="fade-in-up delay-400 flex flex-col sm:flex-row gap-3 md:gap-4 pt-2 md:pt-4 w-full sm:w-auto">
        {/* Botón de WhatsApp */}
        <a class="flex items-center justify-center gap-2 md:gap-3 px-4 py-3 md:px-8 md:py-2 bg-[#25D366] text-blanco-tecnico font-bebas text-xl md:text-2xl tracking-wide rounded-xl hover:brightness-110 hover:scale-105 transition-all shadow-[0_0_15px_rgba(37,211,102,0.2)] text-center w-full sm:w-auto" href="https://wa.me/573247355486?text=Hola,%20vengo%20de%20la%20p%C3%A1gina%20web.%20Quiero%20hacer%20una%20consulta." target="_blank">
          <span class="material-symbols-outlined text-[20px] md:text-[24px]">chat_bubble</span>
          Solicitar por WhatsApp
        </a>
        
        {/* Botón de Llamada */}
      <a href="tel:+573102342263" class="group relative overflow-hidden w-full sm:w-auto flex items-center justify-center p-[2px] rounded-xl bg-grafito hover:scale-105 active:scale-95 transition-all duration-300 shadow-[0_0_15px_rgba(255,152,0,0.1)] hover:shadow-[0_0_30px_rgba(255,152,0,0.5)]">

  {/* 1. Borde animado giratorio (Efecto Shiny puro con Tailwind adaptado al color grafito) */}
  <div class="absolute inset-[-1000%] animate-[spin_3s_linear_infinite] bg-[conic-gradient(from_90deg_at_50%_50%,#0C0907_0%,#FF9800_50%,#0C0907_100%)] opacity-60 group-hover:opacity-100 transition-opacity duration-500"></div>

  {/* 2. Fondo interno para crear la ilusión de borde */}
  {/* Nota: rounded-[10px] ajusta perfectamente dentro del rounded-xl (12px) del contenedor exterior */}
  <div class="absolute inset-[2px] rounded-[10px] bg-grafito group-hover:bg-grafito/80 transition-colors duration-500 z-0"></div>

  {/* 3. Contenido Frontal (Icono y Texto) */}
  {/* Mantiene los paddings originales y cambia el texto a blanco brillante en hover */}
  <span class="relative z-10 flex items-center justify-center gap-2 md:gap-3 px-4 py-3 md:px-8 md:py-2 font-bebas text-xl md:text-2xl tracking-wide text-naranja-dorado w-full transition-all duration-300 group-hover:text-blanco-tecnico group-hover:drop-shadow-[0_0_12px_rgba(255,152,0,0.6)]">
    <span class="material-symbols-outlined text-[20px] md:text-[24px] transition-transform duration-300 group-hover:scale-110">phone_in_talk</span>
    Llamar Ahora
  </span>

</a>
      </div>

    </div>
  </div>
</section>

<style>
  /* Animaciones fluidas de entrada (sin parpadeo) */
  .fade-in-up {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  /* Retrasos escalonados para que los elementos entren uno tras otro */
  .delay-100 { animation-delay: 100ms; }
  .delay-200 { animation-delay: 200ms; }
  .delay-300 { animation-delay: 400ms; }
  .delay-400 { animation-delay: 600ms; }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  // Script para el efecto parallax en scroll
  const parallaxBg = document.getElementById('parallax-bg');

  if (parallaxBg) {
    // Usamos requestAnimationFrame para que la animación sea fluida y no afecte el rendimiento
    let scrollY = window.scrollY;
    let ticking = false;

    const updateParallax = () => {
      // Ajusta el "0.4" para hacer el efecto más rápido o más lento
      parallaxBg.style.transform = `translateY(${scrollY * 0.4}px)`;
      ticking = false;
    };

    window.addEventListener('scroll', () => {
      scrollY = window.scrollY;
      if (!ticking) {
        window.requestAnimationFrame(updateParallax);
        ticking = true;
      }
    });
  }
</script>
